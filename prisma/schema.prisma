generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model equivalencias {
  id             Int      @id @default(autoincrement())
  mazfren_codigo String?  @db.VarChar(50)
  frasle_codigo  String?  @db.VarChar(50)
  frasle         frasle?  @relation(fields: [frasle_codigo], references: [codigo], onDelete: NoAction, onUpdate: NoAction, map: "fk_eq_fra")
  mazfren        mazfren? @relation(fields: [mazfren_codigo], references: [codigo], onDelete: NoAction, onUpdate: NoAction, map: "fk_eq_maz")
}

model frasle {
  id            Int             @id @default(autoincrement())
  codigo        String          @unique @db.VarChar(50)
  descripcion   String
  precio        Decimal?        @db.Decimal(12, 2)
  imagen        String?
  categoria     String?
  fabricante    String?
  equivalencias equivalencias[]
}

model mazfren {
  id            Int             @id @default(autoincrement())
  codigo        String          @unique @db.VarChar(50)
  descripcion   String
  precio        Decimal?        @db.Decimal(12, 2)
  imagen        String?
  categoria     String?
  fabricante    String?
  equivalencias equivalencias[]
}
